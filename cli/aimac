#!/usr/bin/env bash

COMMAND="${1:-}"

case "$COMMAND" in
  doctor)
    shift
    bash scripts/detect.sh "$@"
    ;;
  plan)
    shift
    bash scripts/plan.sh "$@"
    ;;
  apply)
    shift
    bash scripts/apply.sh "$@"
    ;;
  verify)
    shift
    bash scripts/verify.sh "$@"
    ;;
  report)
    shift
    bash scripts/report.sh "$@"
    ;;
  first-success)
    shift
    bash scripts/first-success.sh "$@"
    ;;
  *)
    echo "Usage: aimac {doctor|plan|apply|verify|report}"
    exit 1
    ;;
esac
